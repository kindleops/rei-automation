# NEXUS Dashboard — Environment Variables
# Copy this file to .env.local and fill in the values.
# All VITE_* variables are exposed to the browser bundle.

# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the real-estate-automation Next.js deployment.
# When set, NEXUS routes queue/feeder/inbox actions through this API.
#
# Examples:
#   VITE_BACKEND_API_URL=https://real-estate-automation-three.vercel.app
#   VITE_BACKEND_API_URL=http://localhost:3000
VITE_BACKEND_API_URL=

# ── API authentication ────────────────────────────────────────────────────────
# Must match OPS_DASHBOARD_SECRET on the real-estate-automation server.
# Sent as the x-ops-dashboard-secret HTTP header.
# Leave blank if the server has no secret configured (dev only).
VITE_BACKEND_API_SECRET=

# ── Gemini Underwriter ────────────────────────────────────────────────────────
# Required for autonomous deal research and comp gathering (local dashboard analysis).
GEMINI_API_KEY=

# ── Census API ────────────────────────────────────────────────────────────────
# US Census Bureau API key — server-side only, never exposed to the browser.
# Get a free key at: https://api.census.gov/data/key_signup.html
# Used by: POST /api/internal/census/sync
CENSUS_API_KEY=

# ── Supabase (Optional Dashboard Mirror) ──────────────────────────────────────
# Most writes should go through the Backend API, but some dashboard features
# may optionally read directly from Supabase for performance.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
