# NEXUS Dashboard — Environment Variables
# Copy this file to .env.local and fill in the values.
# All VITE_* variables are exposed to the browser bundle.

# ── Live data API ─────────────────────────────────────────────────────────────
# Base URL of the real-estate-automation Next.js deployment.
# When set, NEXUS fetches live data from /api/internal/dashboard/nexus.
# When unset, the reference mock dataset is used (safe for local dev).
#
# Examples:
#   VITE_NEXUS_API_URL=https://your-app.vercel.app
#   VITE_NEXUS_API_URL=http://localhost:3000
VITE_NEXUS_API_URL=

# ── API authentication ────────────────────────────────────────────────────────
# Must match OPS_DASHBOARD_SECRET on the real-estate-automation server.
# Sent as the x-ops-dashboard-secret HTTP header.
# Leave blank if the server has no secret configured (dev only).
VITE_NEXUS_API_SECRET=

# ── Gemini Underwriter ────────────────────────────────────────────────────────
# Required for autonomous deal research and comp gathering.
GEMINI_API_KEY=

# ── Census API ────────────────────────────────────────────────────────────────
# US Census Bureau API key — server-side only, never exposed to the browser.
# Get a free key at: https://api.census.gov/data/key_signup.html
# Used by: POST /api/internal/census/sync
CENSUS_API_KEY=

