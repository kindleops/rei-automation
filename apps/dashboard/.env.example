# NEXUS Dashboard — Environment Variables
# Copy this file to .env.local and fill in the values.
# All VITE_* variables are exposed to the browser bundle.
#
# SECURITY WARNINGS:
# - NEVER add VITE_SUPABASE_SERVICE_ROLE_KEY to this file or the dashboard.
#   The service_role key bypasses Row Level Security and must never reach the browser.
# - VITE_BACKEND_API_SECRET is browser-visible and temporary.
#   Migrate to Supabase JWT validation when ready (Authorization header is already sent).
# - Supabase Auth is required before any dashboard access.
#   All users must be manually created in the Supabase Auth admin UI.
#   Public signup is disabled — no self-registration UI exists in this app.

# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the real-estate-automation Next.js deployment.
# REQUIRED in production — the dashboard will refuse to operate without this.
# Never default to localhost in production.
VITE_BACKEND_API_URL=https://real-estate-automation-three.vercel.app

# ── API authentication ────────────────────────────────────────────────────────
# Must match OPS_DASHBOARD_SECRET on the real-estate-automation server.
# Sent as the x-ops-dashboard-secret HTTP header.
# Browser-visible — do not use this as a sole security gate in production.
VITE_BACKEND_API_SECRET=

# ── Supabase Auth + Data ──────────────────────────────────────────────────────
# anon key is safe for browser use — RLS policies enforce data access.
# The dashboard uses these for both sign-in auth and direct Supabase reads.
VITE_SUPABASE_URL=https://lcppdrmrdfblstpcbgpf.supabase.co
VITE_SUPABASE_ANON_KEY=

# ── Gemini Underwriter (dev only) ─────────────────────────────────────────────
# Required for autonomous deal research and comp gathering (local analysis only).
# Not needed in production dashboard deployment.
GEMINI_API_KEY=

# ── Census API (dev only) ─────────────────────────────────────────────────────
# US Census Bureau API key — server-side only, never exposed to the browser in prod.
# Get a free key at: https://api.census.gov/data/key_signup.html
# Used by: POST /api/internal/census/sync
CENSUS_API_KEY=
