import { chromium } from '@playwright/test'
import fs from 'node:fs'
import path from 'node:path'

const BASE_URL = process.env.NEXUS_URL || 'http://localhost:5173'
const route = process.env.NEXUS_ROUTE || '/inbox'

const outDir = path.resolve('proof/inbox')
fs.mkdirSync(outDir, { recursive: true })

const stamp = new Date().toISOString().replace(/[:.]/g, '-')
const screenshotPath = path.join(outDir, `inbox-${stamp}.png`)

const browser = await chromium.launch({ headless: true })

const page = await browser.newPage({
  viewport: { width: 1728, height: 1117 },
  deviceScaleFactor: 1,
})

page.on('console', msg => {
  const text = msg.text()

  if (
    text.includes('[NexusInbox') ||
    text.includes('[NexusInboxCounts') ||
    text.includes('[NexusInboxNameResolution') ||
    text.includes('[InboxCoords') ||
    text.includes('[InboxEnrichment') ||
    text.includes('[InboxMap]') ||
    text.includes('[InboxMapSource]') ||
    text.includes('[InboxPage]') ||
    text.includes('[NexusInboxAddressResolution') ||
    text.includes('[AICopilot]') ||
    text.includes('[AICopilotContext]') ||
    text.includes('[BigPickleCopilot]') ||
    text.includes('[AICopilotAction]')
  ) {
    console.log(`[browser-console] ${text}`)
  }
})

await page.goto(`${BASE_URL}${route}`, {
  waitUntil: 'networkidle',
  timeout: 60_000,
})

await page.waitForTimeout(2000)

await page.screenshot({
  path: screenshotPath,
  fullPage: true,
})

console.log(`✅ Inbox screenshot saved: ${screenshotPath}`)

// Map mode screenshot
const mapStamp = new Date().toISOString().replace(/[:.]/g, '-')
const mapScreenshotPath = path.join(outDir, `inbox-map-${mapStamp}.png`)

await page.keyboard.down('Meta')
await page.keyboard.press('m')
await page.keyboard.up('Meta')

await page.waitForTimeout(3000)

await page.screenshot({
  path: mapScreenshotPath,
  fullPage: true,
})

console.log(`✅ Inbox map screenshot saved: ${mapScreenshotPath}`)

// Close map
await page.keyboard.down('Meta')
await page.keyboard.press('m')
await page.keyboard.up('Meta')
await page.waitForTimeout(500)

// AI Copilot proof
console.log('\n── AI Copilot Panel Proof ──')

// Look for AI trigger — it's inside the avatar menu
const avatarMenu = await page.$('.nx-avatar-menu')
if (avatarMenu) {
  await avatarMenu.click()
  await page.waitForTimeout(600)
  // Now click AI Assistant in the dropdown
  const aiMenuItem = await page.$('.nx-avatar-popover button:has-text("AI Assistant")')
  if (aiMenuItem) {
    await aiMenuItem.click()
    console.log('✅ AI overlay trigger found and clicked via avatar menu')
  } else {
    console.log('⚠️ AI Assistant menu item not found in avatar popover')
  }
} else {
  console.log('⚠️ Avatar menu button not found')
}

await page.waitForTimeout(1500)

// Check for copilot panel
const copilotPanel = await page.$('#nx-copilot-panel, .nx-copilot-panel')
if (copilotPanel) {
  console.log('✅ AI Copilot panel rendered')

  // Check agent header
  const agentHeader = await page.$('.nx-copilot-header__info strong')
  if (agentHeader) {
    const name = await agentHeader.textContent()
    console.log(`✅ Agent header visible: ${name}`)
  }

  // Check agent switcher
  const switcher = await page.$('.nx-copilot-switcher__trigger')
  if (switcher) {
    console.log('✅ Agent switcher dropdown present')
    await switcher.click()
    await page.waitForTimeout(500)
    const items = await page.$$('.nx-copilot-switcher__item')
    console.log(`✅ Agent switcher shows ${items.length} agents`)
    // Close switcher by clicking first item (CEO)
    if (items.length > 1) {
      await items[1].click()
      await page.waitForTimeout(300)
      console.log('✅ Agent switch animation completed')
    }
  }

  // Check context capsule
  const context = await page.$('.nx-copilot-context')
  if (context) {
    console.log('✅ Context capsule rendered')
  }

  // Check chat stream
  const msgs = await page.$$('.nx-copilot-msg')
  console.log(`✅ Chat stream has ${msgs.length} message(s)`)

  // Check quick actions
  const quickActions = await page.$$('.nx-copilot-quick-btn')
  console.log(`✅ Quick action buttons: ${quickActions.length}`)

  // Check suggested prompts
  const suggestions = await page.$$('.nx-copilot-suggestion')
  console.log(`✅ Suggested prompts: ${suggestions.length}`)

  // Check advisory badge
  const advisory = await page.$('.nx-copilot-header__badge')
  if (advisory) {
    const badgeText = await advisory.textContent()
    console.log(`✅ Safety mode badge: "${badgeText?.trim()}"`)
  }

  // Screenshot with copilot open
  const copilotStamp = new Date().toISOString().replace(/[:.]/g, '-')
  const copilotScreenshot = path.join(outDir, `inbox-copilot-${copilotStamp}.png`)
  await page.screenshot({ path: copilotScreenshot, fullPage: true })
  console.log(`✅ Copilot screenshot saved: ${copilotScreenshot}`)

  // Test Big Pickle draft via quick action
  const draftBtn = await page.$('.nx-copilot-quick-btn:first-child')
  if (draftBtn) {
    await draftBtn.click()
    await page.waitForTimeout(2000)
    const draftCard = await page.$('.nx-copilot-draft-card')
    if (draftCard) {
      console.log('✅ Big Pickle draft card rendered')
      const internal = await page.$('.nx-copilot-draft-card__internal')
      if (internal) {
        console.log('✅ Internal-only data clearly labeled')
      }
    } else {
      console.log('⚠️ Big Pickle draft card not found (may need thread selected)')
    }

    // Screenshot with draft
    const draftStamp = new Date().toISOString().replace(/[:.]/g, '-')
    const draftScreenshot = path.join(outDir, `inbox-copilot-draft-${draftStamp}.png`)
    await page.screenshot({ path: draftScreenshot, fullPage: true })
    console.log(`✅ Draft screenshot saved: ${draftScreenshot}`)
  }
} else {
  console.log('⚠️ Copilot panel not found in DOM')
}

console.log('\n── Proof Complete ──')
await browser.close()
