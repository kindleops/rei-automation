{
  "framework": "vite",
  "devCommand": "vite --host 0.0.0.0 --port $PORT",
  "buildCommand": "GIT_COMMIT_SHA=${VERCEL_GIT_COMMIT_SHA:-$(git rev-parse HEAD)} VITE_BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/version", "destination": "/api/version" },
    { "source": "/api/internal/dashboard/:path*", "destination": "https://api-steel-three-96.vercel.app/api/internal/dashboard/:path*" },
    { "source": "/api/cockpit/inbox/live", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/inbox/live" },
    { "source": "/api/cockpit/inbox/counts", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/inbox/counts" },
    { "source": "/api/cockpit/inbox/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/inbox/:path*" },
    { "source": "/api/cockpit/health", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/health" },
    { "source": "/api/cockpit/campaigns", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/campaigns" },
    { "source": "/api/cockpit/campaigns/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/campaigns/:path*" },
    { "source": "/api/cockpit/pipeline", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/pipeline" },
    { "source": "/api/cockpit/pipeline/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/pipeline/:path*" },
    { "source": "/api/cockpit/seller-automation", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/seller-automation" },
    { "source": "/api/cockpit/seller-automation/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/seller-automation/:path*" },
    { "source": "/api/cockpit/workflows", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/workflows" },
    { "source": "/api/cockpit/workflows/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/workflows/:path*" },
    { "source": "/api/cockpit/templates", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/templates" },
    { "source": "/api/cockpit/templates/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/templates/:path*" },
    { "source": "/api/cockpit/metrics", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/metrics" },
    { "source": "/api/cockpit/metrics/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/metrics/:path*" },
    { "source": "/api/cockpit/email", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/email" },
    { "source": "/api/cockpit/email/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/email/:path*" },
    { "source": "/api/cockpit/calendar", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/calendar" },
    { "source": "/api/cockpit/calendar/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/calendar/:path*" },
    { "source": "/api/cockpit/threads", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/threads" },
    { "source": "/api/cockpit/threads/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/threads/:path*" },
    { "source": "/api/cockpit/lead-state", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/lead-state" },
    { "source": "/api/cockpit/lead-state/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/lead-state/:path*" },
    { "source": "/api/cockpit/notifications", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/notifications" },
    { "source": "/api/cockpit/notifications/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/notifications/:path*" },
    { "source": "/api/cockpit/queue", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/queue" },
    { "source": "/api/cockpit/queue/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/queue/:path*" },
    { "source": "/api/cockpit/ops", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/ops" },
    { "source": "/api/cockpit/ops/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/ops/:path*" },
    { "source": "/api/cockpit/deal-intelligence", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/deal-intelligence" },
    { "source": "/api/cockpit/deal-intelligence/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/deal-intelligence/:path*" },
    { "source": "/api/cockpit/deal-context", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/deal-context" },
    { "source": "/api/cockpit/deal-context/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/deal-context/:path*" },
    { "source": "/api/cockpit/entity-graph", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/entity-graph" },
    { "source": "/api/cockpit/entity-graph/:path*", "destination": "https://api-steel-three-96.vercel.app/api/cockpit/entity-graph/:path*" },
    { "source": "/api/intel", "destination": "https://api-steel-three-96.vercel.app/api/intel" },
    { "source": "/api/intel/:path*", "destination": "https://api-steel-three-96.vercel.app/api/intel/:path*" },
    { "source": "/api/ops", "destination": "https://api-steel-three-96.vercel.app/api/ops" },
    { "source": "/api/ops/:path*", "destination": "https://api-steel-three-96.vercel.app/api/ops/:path*" },
    { "source": "/api/workflows", "destination": "https://api-steel-three-96.vercel.app/api/workflows" },
    { "source": "/api/workflows/:path*", "destination": "https://api-steel-three-96.vercel.app/api/workflows/:path*" },
    { "source": "/((?!api/|assets/|favicon\\.svg|icons/|manifest\\.webmanifest|sw\\.js|sounds/).*)", "destination": "/index.html" }
  ]
}